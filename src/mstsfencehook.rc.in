// CMake-templated from src/mstsfencehook.rc.in. Do not edit the generated .rc directly.
#include <winres.h>

/////////////////////////////////////////////////////////////////////////////
// Version
/////////////////////////////////////////////////////////////////////////////
VS_VERSION_INFO VERSIONINFO
 FILEVERSION @MSTSFENCE_VERSION_MAJOR@,@MSTSFENCE_VERSION_MINOR@,@MSTSFENCE_VERSION_PATCH@,@MSTSFENCE_VERSION_BUILD@
 PRODUCTVERSION @MSTSFENCE_VERSION_MAJOR@,@MSTSFENCE_VERSION_MINOR@,@MSTSFENCE_VERSION_PATCH@,@MSTSFENCE_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x2L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Marton Anka"
            VALUE "FileDescription",  "mstsfencehook.dll"
            VALUE "FileVersion",      "@MSTSFENCE_VERSION@"
            VALUE "InternalName",     "mstsfencehook.dll"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Marton Anka"
            VALUE "OriginalFilename", "mstsfencehook.dll"
            VALUE "ProductName",      "mstsfence"
            VALUE "ProductVersion",   "@MSTSFENCE_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
