#include <winres.h>

/////////////////////////////////////////////////////////////////////////////
// Version
/////////////////////////////////////////////////////////////////////////////
VS_VERSION_INFO VERSIONINFO
 FILEVERSION @WMLTA_VERSION_MAJOR@,@WMLTA_VERSION_MINOR@,@WMLTA_VERSION_PATCH@,@WMLTA_VERSION_BUILD@
 PRODUCTVERSION @WMLTA_VERSION_MAJOR@,@WMLTA_VERSION_MINOR@,@WMLTA_VERSION_PATCH@,@WMLTA_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x2L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Marton Anka"
            VALUE "FileDescription",  "WM_LEAVEMYTASKBARALONE hook"
            VALUE "FileVersion",      "@WMLTA_VERSION@"
            VALUE "InternalName",     "wmltahook.dll"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Marton Anka"
            VALUE "OriginalFilename", "wmltahook.dll"
            VALUE "ProductName",      "WM_LEAVEMYTASKBARALONE"
            VALUE "ProductVersion",   "@WMLTA_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
