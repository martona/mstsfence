// CMake-templated from src/mstsfence.rc.in. Do not edit the generated .rc directly.
#include <winres.h>
#include "resource.h"

/////////////////////////////////////////////////////////////////////////////
// Icon  (the lowest-ID icon is what Explorer / the shell shows for the .exe)
/////////////////////////////////////////////////////////////////////////////
IDI_MSTSFENCE_ICON ICON "@MSTSFENCE_ICON_PATH@"

/////////////////////////////////////////////////////////////////////////////
// Version
/////////////////////////////////////////////////////////////////////////////
VS_VERSION_INFO VERSIONINFO
 FILEVERSION @MSTSFENCE_VERSION_MAJOR@,@MSTSFENCE_VERSION_MINOR@,@MSTSFENCE_VERSION_PATCH@,@MSTSFENCE_VERSION_BUILD@
 PRODUCTVERSION @MSTSFENCE_VERSION_MAJOR@,@MSTSFENCE_VERSION_MINOR@,@MSTSFENCE_VERSION_PATCH@,@MSTSFENCE_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Marton Anka"
            VALUE "FileDescription",  "mstsfence.exe"
            VALUE "FileVersion",      "@MSTSFENCE_VERSION@"
            VALUE "InternalName",     "mstsfence.exe"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Marton Anka"
            VALUE "OriginalFilename", "mstsfence.exe"
            VALUE "ProductName",      "mstsfence"
            VALUE "ProductVersion",   "@MSTSFENCE_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

/////////////////////////////////////////////////////////////////////////////
// About dialog  (text/icon/link/notice are filled in by AboutDlgProc)
/////////////////////////////////////////////////////////////////////////////
IDD_ABOUT DIALOGEX 0, 0, 300, 128
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About mstsfence"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    CONTROL         "", IDC_ABOUT_ICON, "Static", SS_OWNERDRAW | WS_VISIBLE, 16, 16, 50, 50
    LTEXT           "", IDC_ABOUT_NAME, 72, 18, 214, 14
    LTEXT           "", IDC_ABOUT_VERSION, 72, 34, 214, 10
    LTEXT           "", IDC_ABOUT_COPYRIGHT, 72, 48, 214, 10
    CONTROL         "", IDC_ABOUT_LINK, "SysLink", WS_TABSTOP, 72, 62, 214, 12
    LTEXT           "", IDC_ABOUT_DETOURS, 16, 88, 270, 18
    DEFPUSHBUTTON   "OK", IDOK, 243, 108, 45, 14
END

/////////////////////////////////////////////////////////////////////////////
// Settings dialog
/////////////////////////////////////////////////////////////////////////////
IDD_SETTINGS DIALOGEX 0, 0, 284, 122
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "mstsfence settings"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    AUTOCHECKBOX    "Fence off mstsc.exe and prevent it from encroaching on the taskbar when maximized. The remote resolution adjusts to match this computer's display work area.",
                    IDC_SET_FENCE, 14, 14, 256, 28, BS_TOP | BS_MULTILINE | WS_TABSTOP
    AUTOCHECKBOX    "Dark mode for mstsc.exe. Artwork (such as logos) might not display correctly.",
                    IDC_SET_DARK, 14, 44, 256, 20, BS_TOP | BS_MULTILINE | WS_TABSTOP
    AUTOCHECKBOX    "Override: set the host's DPI scaling to",
                    IDC_SET_DPIOVER, 14, 65, 136, 14, BS_TOP | WS_TABSTOP
    EDITTEXT        IDC_SET_DPIPCT, 154, 65, 26, 13, ES_RIGHT | ES_NUMBER | WS_TABSTOP
    LTEXT           "%", IDC_SET_DPIPCT_LBL, 184, 65, 10, 28
    CONTROL         "", IDC_SET_RVA_STATUS, "Static", SS_RIGHT | WS_CHILD | WS_VISIBLE,
                    14, 90, 258, 8
    DEFPUSHBUTTON   "OK", IDOK, 168, 100, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 222, 100, 50, 14
END
